'================================================================
' 审计报告问题分析汇总工具
' 使用方法：在Excel中按 Alt+F11 打开VBA编辑器，
'           插入新模块，将全部代码粘贴进去，运行 Main 即可
'================================================================

Option Explicit

'-------------------- 主程序 --------------------
Sub Main()
    Dim fso As Object, folder As Object, file As Object
    Dim folderPath As String
    Dim wb As Workbook, wsDetail As Worksheet, wsSummary As Worksheet
    Dim wordApp As Object, doc As Object
    Dim dictAll As Object, dictCategories As Object
    Dim folderItem As Object
    Dim divisionName As String
    Dim dcat As Object

    Set wb = ThisWorkbook

    ' ① 选择文件夹（调用本模块内定义的 BrowseForFolder）
    folderPath = BrowseForFolder("请选择包含审计报告 (.doc/.docx) 的文件夹：")
    If folderPath = "" Then Exit Sub

    Set fso = CreateObject("Scripting.FileSystemObject")
    Set dictAll = CreateObject("Scripting.Dictionary")
    Set dictCategories = CreateObject("Scripting.Dictionary")

    ' ② 启动 Word（复用已有实例，避免重复开启）
    On Error Resume Next
    Set wordApp = GetObject(, "Word.Application")
    If Err.Number <> 0 Then
        Err.Clear
        Set wordApp = CreateObject("Word.Application")
    End If
    On Error GoTo 0
    wordApp.Visible = False

    ' ③ 遍历文件夹内所有 doc/docx 文件
    Set folder = fso.GetFolder(folderPath)
    For Each file In folder.Files
        If LCase(fso.GetExtensionName(file.Name)) = "doc" Or _
           LCase(fso.GetExtensionName(file.Name)) = "docx" Then

            On Error Resume Next
            Set doc = wordApp.Documents.Open(file.Path, ReadOnly:=True, AddToRecentFiles:=False)
            If Err.Number <> 0 Then
                Err.Clear
                GoTo NextFile
            End If
            On Error GoTo 0

            ' ④ 提取事业部名称（调用本模块内定义的 ExtractDivisionName）
            divisionName = ExtractDivisionName(doc, file.Name)
            If divisionName = "" Then
                divisionName = Left(file.Name, InStrRev(file.Name, ".") - 1)
            End If

            ' ⑤ 初始化该事业部的字典
            If Not dictAll.Exists(divisionName) Then
                Set dcat = CreateObject("Scripting.Dictionary")
                dictAll.Add divisionName, dcat
            Else
                Set dcat = dictAll(divisionName)
            End If

            ' ⑥ 提取问题条目
            Call ExtractProblems(doc, dcat, dictCategories)

            doc.Close SaveChanges:=False
        End If
NextFile:
    Next file

    ' ⑦ 关闭 Word
    wordApp.Quit
    Set wordApp = Nothing

    ' ⑧ 写入 Excel
    Call WriteToExcel(wb, dictAll, dictCategories)

    MsgBox "分析完成！请查看【明细】和【汇总】工作表。", vbInformation
End Sub


'-------------------- ① 浏览文件夹对话框 --------------------
Function BrowseForFolder(prompt As String) As String
    Dim shell As Object
    Dim shellFolder As Object

    Set shell = CreateObject("Shell.Application")
    Set shellFolder = shell.BrowseForFolder(0, prompt, 0, "")

    If shellFolder Is Nothing Then
        BrowseForFolder = ""
    Else
        BrowseForFolder = shellFolder.Self.Path
    End If
End Function


'-------------------- ② 提取事业部名称 --------------------
' 策略：优先从文档标题段落或文件名中找"XX事业部"字样
Function ExtractDivisionName(doc As Object, fileName As String) As String
    Dim para As Object
    Dim txt As String
    Dim result As String
    result = ""

    ' 从前10段中寻找含"事业部"或"分公司"或"部门"的段落
    Dim i As Integer
    For i = 1 To IIf(doc.Paragraphs.Count < 10, doc.Paragraphs.Count, 10)
        txt = Trim(doc.Paragraphs(i).Range.Text)
        If InStr(txt, "事业部") > 0 Or InStr(txt, "分公司") > 0 Or InStr(txt, "部门") > 0 Then
            result = txt
            Exit For
        End If
    Next i

    ' 若文档中未找到，则从文件名提取
    If result = "" Then
        Dim baseName As String
        baseName = Left(fileName, InStrRev(fileName, ".") - 1)
        If InStr(baseName, "事业部") > 0 Or InStr(baseName, "分公司") > 0 Then
            result = baseName
        Else
            result = baseName  ' 兜底：直接用文件名（去扩展名）
        End If
    End If

    ' 截断过长的字符串（最多保留前20字）
    If Len(result) > 20 Then result = Left(result, 20)

    ExtractDivisionName = result
End Function


'-------------------- ③ 提取问题条目 --------------------
' 逻辑：
'   - 一级标题（如"一、业务发展方面"）→ 记为大类
'   - 二级标题（如"（一）贷款业务存在…"）→ 记为具体问题
Sub ExtractProblems(doc As Object, dcat As Object, dictCategories As Object)
    Dim para As Object
    Dim txt As String
    Dim currentCategory As String
    currentCategory = "未分类"

    Dim styleLevel As Integer

    For Each para In doc.Paragraphs
        txt = Trim(para.Range.Text)
        If Len(txt) < 2 Then GoTo NextPara

        ' 判断段落样式级别
        styleLevel = GetHeadingLevel(para)

        Select Case styleLevel
            Case 1  ' 一级标题 → 大类（如"业务发展方面"）
                currentCategory = CleanText(txt)
                ' 登记大类
                If Not dictCategories.Exists(currentCategory) Then
                    dictCategories.Add currentCategory, 0
                End If

            Case 2  ' 二级标题 → 具体问题条目
                Dim problem As String
                problem = CleanText(txt)
                If problem <> "" Then
                    Dim key As String
                    key = currentCategory & "|" & problem
                    If dcat.Exists(key) Then
                        dcat(key) = dcat(key) + 1
                    Else
                        dcat.Add key, 1
                    End If
                    ' 同步登记到全局问题库
                    If Not dictCategories.Exists(key) Then
                        dictCategories.Add key, 0
                    End If
                    dictCategories(key) = dictCategories(key) + 1
                End If
        End Select
NextPara:
    Next para
End Sub


'-------------------- ④ 判断标题级别 --------------------
Function GetHeadingLevel(para As Object) As Integer
    Dim styleName As String
    On Error Resume Next
    styleName = para.Style.NameLocal
    On Error GoTo 0

    ' 匹配Word内置标题样式
    If InStr(styleName, "标题 1") > 0 Or InStr(styleName, "Heading 1") > 0 Then
        GetHeadingLevel = 1
    ElseIf InStr(styleName, "标题 2") > 0 Or InStr(styleName, "Heading 2") > 0 Then
        GetHeadingLevel = 2
    ElseIf InStr(styleName, "标题 3") > 0 Or InStr(styleName, "Heading 3") > 0 Then
        GetHeadingLevel = 2  ' 三级也归为细项
    Else
        ' 兜底：用正则匹配常见中文编号格式
        Dim txt As String
        txt = Trim(para.Range.Text)
        ' 一级：一、二、三、四、五……
        If txt Like "[一二三四五六七八九十]、*" Then
            GetHeadingLevel = 1
        ' 二级：（一）（二）或 1. 2. 等
        ElseIf txt Like "（[一二三四五六七八九十]）*" Or txt Like "([一二三四五六七八九十])*" Then
            GetHeadingLevel = 2
        ElseIf txt Like "[0-9]*．*" Or txt Like "[0-9]*.*" And Len(txt) < 50 Then
            GetHeadingLevel = 2
        Else
            GetHeadingLevel = 0
        End If
    End If
End Function


'-------------------- ⑤ 清洗文本 --------------------
Function CleanText(txt As String) As String
    ' 去除段落标记、换行、多余空格
    Dim result As String
    result = Replace(txt, Chr(13), "")
    result = Replace(result, Chr(10), "")
    result = Replace(result, Chr(7), "")   ' Word段落符
    result = Trim(result)
    CleanText = result
End Function


'-------------------- ⑥ 写入Excel --------------------
Sub WriteToExcel(wb As Workbook, dictAll As Object, dictCategories As Object)
    '--- 准备工作表 ---
    Dim wsDetail As Worksheet, wsSummary As Worksheet

    ' 明细表
    On Error Resume Next
    Set wsDetail = wb.Sheets("问题明细")
    On Error GoTo 0
    If wsDetail Is Nothing Then
        Set wsDetail = wb.Sheets.Add(After:=wb.Sheets(wb.Sheets.Count))
        wsDetail.Name = "问题明细"
    Else
        wsDetail.Cells.Clear
    End If

    ' 汇总表
    On Error Resume Next
    Set wsSummary = wb.Sheets("频次汇总")
    On Error GoTo 0
    If wsSummary Is Nothing Then
        Set wsSummary = wb.Sheets.Add(After:=wsDetail)
        wsSummary.Name = "频次汇总"
    Else
        wsSummary.Cells.Clear
    End If

    '============================
    ' 【明细表】布局：
    '   行1 = 表头（事业部名称横向排列）
    '   列A = 大类
    '   列B = 具体问题
    '   列C起 = 各事业部是否出现（1/空）
    '============================

    Dim divisions() As String
    Dim divCount As Integer
    divCount = dictAll.Count
    ReDim divisions(1 To divCount)

    Dim k As Integer, d As Variant
    k = 1
    For Each d In dictAll.Keys
        divisions(k) = d
        k = k + 1
    Next d

    ' 写表头
    wsDetail.Cells(1, 1).Value = "大类"
    wsDetail.Cells(1, 2).Value = "具体问题"
    Dim col As Integer
    For col = 1 To divCount
        wsDetail.Cells(1, col + 2).Value = divisions(col)
    Next col

    ' 收集所有细项问题（key格式：大类|具体问题）
    Dim allKeys As Object
    Set allKeys = CreateObject("Scripting.Dictionary")
    Dim divDict As Object, ky As Variant
    For Each d In dictAll.Keys
        Set divDict = dictAll(d)
        For Each ky In divDict.Keys
            If Not allKeys.Exists(ky) Then allKeys.Add ky, 0
        Next ky
    Next d

    ' 按大类排序写入（简单插入排序）
    Dim sortedKeys() As String
    Dim skCount As Integer
    skCount = allKeys.Count
    ReDim sortedKeys(1 To IIf(skCount > 0, skCount, 1))
    k = 1
    For Each ky In allKeys.Keys
        sortedKeys(k) = ky
        k = k + 1
    Next ky
    ' 简单冒泡排序（按大类字母序）
    Dim i As Integer, j As Integer, tmp As String
    For i = 1 To skCount - 1
        For j = 1 To skCount - i
            If sortedKeys(j) > sortedKeys(j + 1) Then
                tmp = sortedKeys(j)
                sortedKeys(j) = sortedKeys(j + 1)
                sortedKeys(j + 1) = tmp
            End If
        Next j
    Next i

    ' 写数据行
    Dim row As Integer
    row = 2
    Dim parts() As String
    For i = 1 To skCount
        parts = Split(sortedKeys(i), "|")
        If UBound(parts) >= 1 Then
            wsDetail.Cells(row, 1).Value = parts(0)   ' 大类
            wsDetail.Cells(row, 2).Value = parts(1)   ' 具体问题
        Else
            wsDetail.Cells(row, 1).Value = sortedKeys(i)
        End If
        ' 各事业部出现标记
        For col = 1 To divCount
            Set divDict = dictAll(divisions(col))
            If divDict.Exists(sortedKeys(i)) Then
                wsDetail.Cells(row, col + 2).Value = 1
            Else
                wsDetail.Cells(row, col + 2).Value = ""
            End If
        Next col
        row = row + 1
    Next i

    ' 在最后一行加合计
    wsDetail.Cells(row, 1).Value = "合计"
    For col = 1 To divCount
        wsDetail.Cells(row, col + 2).Formula = _
            "=SUM(" & wsDetail.Cells(2, col + 2).Address & ":" & _
            wsDetail.Cells(row - 1, col + 2).Address & ")"
    Next col

    '============================
    ' 【汇总表】布局：
    '   行=大类, 列=事业部, 值=该事业部在该大类下出现的细项数
    '============================

    ' 收集大类列表
    Dim allCats As Object
    Set allCats = CreateObject("Scripting.Dictionary")
    For i = 1 To skCount
        parts = Split(sortedKeys(i), "|")
        If UBound(parts) >= 1 Then
            If Not allCats.Exists(parts(0)) Then allCats.Add parts(0), 0
        End If
    Next i

    Dim cats() As String
    Dim catCount As Integer
    catCount = allCats.Count
    ReDim cats(1 To IIf(catCount > 0, catCount, 1))
    k = 1
    For Each ky In allCats.Keys
        cats(k) = ky
        k = k + 1
    Next ky

    ' 写汇总表表头
    wsSummary.Cells(1, 1).Value = "大类 \ 事业部"
    For col = 1 To divCount
        wsSummary.Cells(1, col + 1).Value = divisions(col)
    Next col
    wsSummary.Cells(1, divCount + 2).Value = "合计出现次数"

    ' 写汇总数据
    For i = 1 To catCount
        wsSummary.Cells(i + 1, 1).Value = cats(i)
        Dim total As Integer
        total = 0
        For col = 1 To divCount
            Set divDict = dictAll(divisions(col))
            Dim cnt As Integer
            cnt = 0
            ' 统计该事业部在该大类下的细项数
            For Each ky In divDict.Keys
                parts = Split(ky, "|")
                If UBound(parts) >= 1 Then
                    If parts(0) = cats(i) Then cnt = cnt + 1
                End If
            Next ky
            wsSummary.Cells(i + 1, col + 1).Value = cnt
            total = total + cnt
        Next col
        wsSummary.Cells(i + 1, divCount + 2).Value = total
    Next i

    ' 汇总表最后一行：各事业部总问题数
    wsSummary.Cells(catCount + 2, 1).Value = "总计"
    For col = 1 To divCount
        wsSummary.Cells(catCount + 2, col + 1).Formula = _
            "=SUM(" & wsSummary.Cells(2, col + 1).Address & ":" & _
            wsSummary.Cells(catCount + 1, col + 1).Address & ")"
    Next col

    '--- 美化 ---
    Call FormatSheets(wsDetail, wsSummary, divCount, row, catCount)

    ' 跳转到汇总表
    wsSummary.Activate
End Sub


'-------------------- ⑦ 格式美化 --------------------
Sub FormatSheets(wsDetail As Worksheet, wsSummary As Worksheet, _
                 divCount As Integer, detailLastRow As Integer, catCount As Integer)

    Dim rng As Range
    Dim headerColor As Long
    headerColor = RGB(31, 78, 121)   ' 深蓝

    ' === 明细表 ===
    With wsDetail
        ' 表头行
        Set rng = .Range(.Cells(1, 1), .Cells(1, divCount + 2))
        With rng
            .Interior.Color = headerColor
            .Font.Color = RGB(255, 255, 255)
            .Font.Bold = True
            .HorizontalAlignment = xlCenter
        End With

        ' 合计行
        Set rng = .Range(.Cells(detailLastRow, 1), .Cells(detailLastRow, divCount + 2))
        With rng
            .Interior.Color = RGB(189, 215, 238)
            .Font.Bold = True
        End With

        ' 大类列背景色
        Set rng = .Range(.Cells(2, 1), .Cells(detailLastRow - 1, 1))
        rng.Interior.Color = RGB(221, 235, 247)

        ' 边框
        Set rng = .Range(.Cells(1, 1), .Cells(detailLastRow, divCount + 2))
        rng.Borders.LineStyle = xlContinuous
        rng.Borders.Weight = xlThin

        ' 自动列宽
        .Columns.AutoFit
        ' 限制A、B列宽
        .Columns(1).ColumnWidth = 18
        .Columns(2).ColumnWidth = 35
        ' 数值列居中
        .Range(.Cells(2, 3), .Cells(detailLastRow, divCount + 2)).HorizontalAlignment = xlCenter

        ' 冻结首行
        .Activate
        ActiveWindow.FreezePanes = False
        .Rows(2).Select
        ActiveWindow.FreezePanes = True
    End With

    ' === 汇总表 ===
    With wsSummary
        ' 表头行
        Set rng = .Range(.Cells(1, 1), .Cells(1, divCount + 2))
        With rng
            .Interior.Color = headerColor
            .Font.Color = RGB(255, 255, 255)
            .Font.Bold = True
            .HorizontalAlignment = xlCenter
        End With

        ' 合计列
        Set rng = .Range(.Cells(1, divCount + 2), .Cells(catCount + 2, divCount + 2))
        rng.Interior.Color = RGB(255, 242, 204)
        rng.Font.Bold = True

        ' 总计行
        Set rng = .Range(.Cells(catCount + 2, 1), .Cells(catCount + 2, divCount + 2))
        rng.Interior.Color = RGB(189, 215, 238)
        rng.Font.Bold = True

        ' 边框
        Set rng = .Range(.Cells(1, 1), .Cells(catCount + 2, divCount + 2))
        rng.Borders.LineStyle = xlContinuous
        rng.Borders.Weight = xlThin

        ' 数值居中
        .Range(.Cells(2, 2), .Cells(catCount + 2, divCount + 2)).HorizontalAlignment = xlCenter

        .Columns.AutoFit
        .Columns(1).ColumnWidth = 20

        ' 条件格式：值越大颜色越深
        Dim dataRng As Range
        Set dataRng = .Range(.Cells(2, 2), .Cells(catCount + 1, divCount + 1))
        dataRng.FormatConditions.AddColorScale ColorScaleType:=3
        dataRng.FormatConditions(dataRng.FormatConditions.Count).ColorScaleCriteria(1).FormatColor.Color = RGB(255, 255, 255)
        dataRng.FormatConditions(dataRng.FormatConditions.Count).ColorScaleCriteria(3).FormatColor.Color = RGB(31, 78, 121)
    End With
End Sub
